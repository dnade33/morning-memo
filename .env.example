# Morning Memo — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Supabase — Settings > API in your Supabase dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anthropic — platform.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Resend — resend.com
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=memo@yourdomain.com

# App
PORT=3001
NODE_ENV=development

# Cron trigger secret — used to protect /api/run-cron from unauthorized calls
CRON_SECRET=your-secret-here
